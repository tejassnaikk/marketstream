# Dockerfile.watchdog
#
# Watchdog service for MarketStream.
# Monitors Kafka message flow and API health every 60 seconds.

FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1

WORKDIR /app

RUN pip install --no-cache-dir \
    kafka-python-ng \
    requests

COPY scripts/watchdog.py /app/scripts/watchdog.py

RUN mkdir -p /app/logs

CMD ["python", "scripts/watchdog.py"]
